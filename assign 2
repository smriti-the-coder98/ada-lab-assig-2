    ('j4', 3, 18),
    ('j5', 2, 1),
    ('j6', 1, 6),
    ('j7', 2, 30)
]

print("Job Sequencing:", job_sequencing(jobs))


# ----------------------------
# Q5: LCS (Dynamic Programming)
# ----------------------------

def lcs(X, Y):
    m, n = len(X), len(Y)
    dp = [[0] * (n + 1) for _ in range(m + 1)]

    for i in range(1, m + 1):
        for j in range(1, n + 1):
            if X[i - 1] == Y[j - 1]:
                dp[i][j] = dp[i - 1][j - 1] + 1
            else:
                dp[i][j] = max(dp[i - 1][j], dp[i][j - 1])

    return dp[m][n]


