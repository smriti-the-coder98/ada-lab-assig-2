# Q4: Job Sequencing
# ----------------------------

def job_sequencing(jobs):
    jobs.sort(key=lambda x: x[2], reverse=True)

    max_deadline = max(job[1] for job in jobs)
    slots = [-1] * max_deadline
    profit = 0

    for job in jobs:
        for j in range(job[1] - 1, -1, -1):
            if slots[j] == -1:
                slots[j] = job[0]
                profit += job[2]
                break

    return slots, profit


jobs = [
    ('j1', 1, 3),
