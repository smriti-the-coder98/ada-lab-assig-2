# Q3: Fractional Knapsack
# ----------------------------

def fractional_knapsack(weights, values, capacity):
    items = list(zip(weights, values))
    items.sort(key=lambda x: x[1] / x[0], reverse=True)

    total = 0

    for w, v in items:
        if capacity >= w:
            total += v
            capacity -= w
        else:
            total += (v / w) * capacity
            break

    return total


